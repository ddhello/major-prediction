{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "major-prediction",
  "main": "worker.js",
  "compatibility_date": "2026-06-12",
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
      "binding": "MAJOR_STATE",
      "id": "9d8bbeba8d0645d78c3a98c8cc016193"
    }
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  }
}
