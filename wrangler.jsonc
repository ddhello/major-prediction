{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "major-prediction",
  "main": "worker.js",
  "compatibility_date": "2026-06-12",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  }
}
